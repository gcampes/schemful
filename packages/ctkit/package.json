{
  "name": "@ctkit/cli",
  "version": "0.1.1",
  "description": "Content Type Kit — a Drizzle ORM-style workflow for managing Contentful content models",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/Field.d.ts",
      "default": "./dist/types/Field.js"
    },
    "./utils": {
      "types": "./dist/utils/validators.d.ts",
      "default": "./dist/utils/validators.js"
    },
    "./client": {
      "types": "./dist/utils/contentfulClient.d.ts",
      "default": "./dist/utils/contentfulClient.js"
    }
  },
  "bin": {
    "ctkit": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "refresh": "pnpm run build && pnpm link --global",
    "start": "tsx src/cli.ts",
    "type-check": "tsc --noEmit",
    "test": "vitest --config vitest.config.mts",
    "test:run": "vitest run --config vitest.config.mts",
    "test:ui": "vitest --ui --config vitest.config.mts",
    "test:coverage": "vitest run --coverage --config vitest.config.mts",
    "test:integration": "vitest run --config vitest.integration.config.mts",
    "prepare": "pnpm run build",
    "prepublishOnly": "pnpm run build && pnpm run type-check",
    "link": "pnpm run build && pnpm link --global",
    "unlink": "pnpm unlink --global @ctkit/cli",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "contentful",
    "cms",
    "schema",
    "migration",
    "content-type",
    "drizzle",
    "typescript",
    "cli"
  ],
  "author": "gcampes",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gcampes/ctkit.git"
  },
  "homepage": "https://ctkit.dev",
  "bugs": {
    "url": "https://github.com/gcampes/ctkit/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "contentful-management": "^11.34.5",
    "contentful-migration": "^4.28.6",
    "dotenv": "^16.6.1",
    "esbuild": "^0.24.2",
    "inquirer": "^8.2.6",
    "lodash": "^4.17.21",
    "ora": "^5.4.1",
    "tsx": "^4.20.3",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/inquirer": "^8.2.10",
    "@types/lodash": "^4.17.20",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "3.2.4",
    "@vitest/ui": "^3.2.4",
    "c8": "^10.1.3",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
