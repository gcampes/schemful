{
  "name": "ctkit-monorepo",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm --filter @ctkit/cli test:run",
    "test:integration": "pnpm --filter @ctkit/cli test:integration",
    "type-check": "pnpm -r type-check",
    "clean": "pnpm -r clean",
    "publish-packages": "./scripts/publish.sh",
    "release": "./scripts/publish.sh",
    "link-local": "./scripts/link-local.sh",
    "smoke": "./scripts/smoke.sh"
  },
  "packageManager": "pnpm@10.7.0",
  "engines": {
    "node": ">=18"
  }
}
