---
interface Props {
  title?: string;
}

const { title = "Terminal" } = Astro.props;
---

<div class="terminal-block group relative overflow-hidden rounded-2xl border border-[var(--color-border)]">
  <div class="flex items-center gap-2 border-b border-[var(--color-border)] bg-[var(--color-bg-subtle)] px-4 py-3">
    <div class="flex gap-1.5">
      <span class="h-3 w-3 rounded-full bg-[#ef4444]/60"></span>
      <span class="h-3 w-3 rounded-full bg-[#eab308]/60"></span>
      <span class="h-3 w-3 rounded-full bg-[#22c55e]/60"></span>
    </div>
    <span class="ml-2 text-xs text-[var(--color-text-subtle)]">{title}</span>
  </div>
  <div class="terminal-content bg-[var(--color-bg-subtle)] p-5 font-mono text-[0.8125rem] leading-[1.75]">
    <slot />
  </div>
</div>
