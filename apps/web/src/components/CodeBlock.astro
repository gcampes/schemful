---
import { Code } from "astro:components";

interface Props {
  code: string;
  lang?: string;
  filename?: string;
  showDots?: boolean;
}

const { code, lang = "typescript", filename, showDots = true } = Astro.props;
---

<div class="code-block group relative overflow-hidden rounded-2xl border border-[var(--color-border)]">
  {(filename || showDots) && (
    <div class="flex items-center gap-2 border-b border-[var(--color-border)] bg-[var(--color-bg-subtle)] px-4 py-3">
      {showDots && (
        <div class="flex gap-1.5">
          <span class="h-3 w-3 rounded-full bg-[#ef4444]/60"></span>
          <span class="h-3 w-3 rounded-full bg-[#eab308]/60"></span>
          <span class="h-3 w-3 rounded-full bg-[#22c55e]/60"></span>
        </div>
      )}
      {filename && (
        <span class="ml-2 text-xs text-[var(--color-text-subtle)]">{filename}</span>
      )}
    </div>
  )}
  <div class="code-content overflow-hidden">
    <Code code={code} lang={lang} theme="github-dark-default" />
  </div>
</div>

<style>
  .code-content :global(pre) {
    margin: 0 !important;
    border: none !important;
    border-radius: 0 !important;
    background-color: var(--color-bg-subtle) !important;
    padding: 1.25rem !important;
    font-size: 0.8125rem !important;
    line-height: 1.75 !important;
    overflow-x: auto !important;
  }

  .code-content :global(code) {
    font-family: var(--font-mono) !important;
  }

  .code-content :global(.astro-code) {
    max-width: 100% !important;
    overflow-x: auto !important;
  }
</style>
